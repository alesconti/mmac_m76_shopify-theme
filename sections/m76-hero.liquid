<style>
.m76-hero {
  position: relative;
  height: {{ section.settings.height }}vh;
  min-height: 560px;
  overflow: hidden;
  background: #1d2440;
  display: block;
}
.m76-hero__bg { position: absolute; inset: 0; }
.m76-hero__bg img { width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: .72; display: block; }
.m76-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 15%, rgba(29,36,64,.88) 100%);
}
.m76-hero__content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 0 52px 72px;
  max-width: 820px;
}
.m76-hero__eyebrow {
  font-family: 'Poppins', sans-serif;
  font-size: 15px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #f4f4d0;
  opacity: .8;
  margin: 0 0 20px;
}
.m76-hero__quote {
  font-family: 'Playfair Display', serif;
  font-size: 38px;
  font-weight: 400;
  line-height: 1.45;
  color: #fff;
  margin: 0 0 16px;
  padding: 0;
  border: none;
}
.m76-hero__author {
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,.45);
  margin: 0 0 40px;
}
.m76-hero__ctas { display: flex; gap: 16px; flex-wrap: wrap; }
.m76-hero__btn {
  font-family: 'Poppins', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  text-decoration: none;
  padding: 16px 32px;
  display: inline-block;
  transition: all .2s;
  border: 1px solid transparent;
}
.m76-hero__btn--primary { background: #fff; color: #1d2440; }
.m76-hero__btn--primary:hover { background: #f4f4d0; }
.m76-hero__btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,.4); }
.m76-hero__btn--outline:hover { border-color: #fff; }

@media (max-width: 749px) {
  .m76-hero__content { padding: 0 20px 48px; }
  .m76-hero__quote { font-size: 26px; }
  .m76-hero__eyebrow { font-size: 11px; }
}
</style>

<section class="m76-hero">
  {%- if section.settings.image != blank -%}
    <div class="m76-hero__bg">
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '750, 1100, 1500, 1780, 2000, 2400'
      }}
    </div>
  {%- endif -%}

  <div class="m76-hero__overlay"></div>

  <div class="m76-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="m76-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.quote != blank -%}
      <blockquote class="m76-hero__quote">{{ section.settings.quote }}</blockquote>
    {%- endif -%}

    {%- if section.settings.author != blank -%}
      <p class="m76-hero__author">{{ section.settings.author }}</p>
    {%- endif -%}

    <div class="m76-hero__ctas">
      {%- if section.settings.cta1_label != blank -%}
        <a href="{{ section.settings.cta1_link }}" class="m76-hero__btn m76-hero__btn--primary">
          {{ section.settings.cta1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta2_label != blank -%}
        <a href="{{ section.settings.cta2_link }}" class="m76-hero__btn m76-hero__btn--outline">
          {{ section.settings.cta2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero principale",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine di sfondo"
    },
    {
      "type": "range",
      "id": "height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Altezza hero",
      "default": 90
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Occhiello (testo piccolo sopra)",
      "default": "Design Italiano"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Citazione / Headline",
      "default": "«I vostri figli e nipoti vi ricorderanno anche dai mobili ereditati.»"
    },
    {
      "type": "text",
      "id": "author",
      "label": "Autore citazione",
      "default": "— Dino Gavina"
    },
    {
      "type": "header",
      "content": "CTA principale"
    },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "Testo pulsante 1",
      "default": "Sfoglia il catalogo"
    },
    {
      "type": "url",
      "id": "cta1_link",
      "label": "Link pulsante 1"
    },
    {
      "type": "header",
      "content": "CTA secondaria"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Testo pulsante 2",
      "default": "Noleggio per set"
    },
    {
      "type": "url",
      "id": "cta2_link",
      "label": "Link pulsante 2"
    }
  ],
  "presets": [{ "name": "Hero M76" }]
}
{% endschema %}
