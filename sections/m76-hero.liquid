<style>
.m76-hero-split {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  height: 70vh;
  max-height: 720px;
  min-height: 480px;
  overflow: hidden;
}

/* ── LEFT: testo ── */
.m76-hero-split__left {
  background: #fff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 60px 80px 52px;
  overflow: hidden;
}
.m76-hero-split__eyebrow {
  font-family: 'Poppins', sans-serif;
  font-size: 15px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #8a8c96;
  margin: 0 0 36px;
}
.m76-hero-split__quote {
  font-family: 'Playfair Display', serif;
  font-style: normal; /* override del blockquote italic di base.css */
  font-size: 36px;
  font-weight: 400;
  line-height: 1.45;
  color: #1d2440;
  margin: 0 0 20px;
  padding: 0;
  border: none;
}
.m76-hero-split__author {
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  letter-spacing: 2px;
  color: #8a8c96;
  margin: 0 0 52px;
}
.m76-hero-split__ctas { display: flex; gap: 16px; flex-wrap: wrap; }
.m76-hero-split__btn {
  font-family: 'Poppins', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  text-decoration: none;
  padding: 16px 32px;
  display: inline-block;
  transition: all .2s;
  border: 1px solid transparent;
}
.m76-hero-split__btn--primary { background: #1d2440; color: #fff; border-color: #1d2440; }
.m76-hero-split__btn--primary:hover { opacity: .85; }
.m76-hero-split__btn--outline { background: transparent; color: #1d2440; border-color: #e4e4dc; }
.m76-hero-split__btn--outline:hover { background: #1d2440; color: #fff; border-color: #1d2440; }

/* ── RIGHT: slideshow ── */
.m76-hero-split__slideshow {
  position: relative;
  overflow: hidden;
  background: #1d2440;
}
.m76-hero-split__slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity .9s ease;
}
.m76-hero-split__slide.is-active { opacity: 1; }
.m76-hero-split__slide img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.m76-hero-split__placeholder {
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f8f4;
}
.m76-hero-split__placeholder svg { width: 100%; height: 100%; opacity: .3; }

/* caption + dots overlay */
.m76-hero-split__cap {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 28px 32px;
  background: linear-gradient(to top, rgba(29,36,64,.7) 0%, transparent 100%);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
}
.m76-hero-split__cap-text {
  font-family: 'Poppins', sans-serif;
  font-size: 13px;
  font-weight: 300;
  color: rgba(255,255,255,.65);
  letter-spacing: 1px;
  margin: 0;
  min-height: 1em;
}
.m76-hero-split__dots { display: flex; gap: 8px; flex-shrink: 0; }
.m76-hero-split__dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: rgba(255,255,255,.3);
  border: none; cursor: pointer; padding: 0;
  transition: background .25s;
}
.m76-hero-split__dot.is-active { background: #fff; }

/* ── RESPONSIVE ── */
@media (max-width: 989px) {
  .m76-hero-split {
    grid-template-columns: 1fr;
    min-height: 0;
  }
  .m76-hero-split__slideshow {
    order: -1;
    min-height: 60vw;
    position: relative;
  }
  .m76-hero-split__left { padding: 48px 20px 52px; }
  .m76-hero-split__quote { font-size: 26px; }
  .m76-hero-split__eyebrow { margin-bottom: 24px; }
  .m76-hero-split__author { margin-bottom: 36px; }
}
</style>

<section class="m76-hero-split">

  <!-- ── LEFT ── -->
  <div class="m76-hero-split__left">
    {%- if section.settings.eyebrow != blank -%}
      <p class="m76-hero-split__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.quote != blank -%}
      <blockquote class="m76-hero-split__quote">{{ section.settings.quote }}</blockquote>
    {%- endif -%}

    {%- if section.settings.author != blank -%}
      <p class="m76-hero-split__author">{{ section.settings.author }}</p>
    {%- endif -%}

    <div class="m76-hero-split__ctas">
      {%- if section.settings.cta1_label != blank -%}
        <a href="{{ section.settings.cta1_link | default: '/collections/all' }}" class="m76-hero-split__btn m76-hero-split__btn--primary">
          {{ section.settings.cta1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta2_label != blank -%}
        <a href="{{ section.settings.cta2_link | default: '/pages/noleggio' }}" class="m76-hero-split__btn m76-hero-split__btn--outline">
          {{ section.settings.cta2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <!-- ── RIGHT: slideshow ── -->
  <div class="m76-hero-split__slideshow" id="m76hs-{{ section.id }}">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div
          class="m76-hero-split__slide{% if forloop.first %} is-active{% endif %}"
          data-caption="{{ block.settings.caption | escape }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {%- if forloop.first -%}
              {{
                block.settings.image
                | image_url: width: 1600
                | image_tag:
                  loading: 'eager',
                  fetchpriority: 'high',
                  sizes: '(max-width: 989px) 100vw, 55vw',
                  widths: '750, 1100, 1600'
              }}
            {%- else -%}
              {{
                block.settings.image
                | image_url: width: 1600
                | image_tag:
                  loading: 'lazy',
                  sizes: '(max-width: 989px) 100vw, 55vw',
                  widths: '750, 1100, 1600'
              }}
            {%- endif -%}
          {%- else -%}
            <div class="m76-hero-split__placeholder">
              {{ 'lifestyle-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <div class="m76-hero-split__cap">
        <p class="m76-hero-split__cap-text" id="m76hs-cap-{{ section.id }}">
          {{- section.blocks.first.settings.caption -}}
        </p>
        {%- if section.blocks.size > 1 -%}
          <div class="m76-hero-split__dots" role="tablist" aria-label="Slide">
            {%- for block in section.blocks -%}
              <button
                class="m76-hero-split__dot{% if forloop.first %} is-active{% endif %}"
                data-index="{{ forloop.index0 }}"
                aria-label="Slide {{ forloop.index }}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="m76-hero-split__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}
  </div>

</section>

{%- if section.blocks.size > 1 -%}
<script>
(function () {
  var wrap    = document.getElementById('m76hs-{{ section.id }}');
  if (!wrap) return;
  var slides  = wrap.querySelectorAll('.m76-hero-split__slide');
  var dots    = wrap.querySelectorAll('.m76-hero-split__dot');
  var cap     = document.getElementById('m76hs-cap-{{ section.id }}');
  var current = 0;
  var timer   = null;

  function goTo(n) {
    slides[current].classList.remove('is-active');
    if (dots[current]) { dots[current].classList.remove('is-active'); dots[current].setAttribute('aria-selected','false'); }
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('is-active');
    if (dots[current]) { dots[current].classList.add('is-active'); dots[current].setAttribute('aria-selected','true'); }
    if (cap) cap.textContent = slides[current].dataset.caption || '';
  }

  function start() { timer = setInterval(function () { goTo(current + 1); }, 5000); }
  function stop()  { clearInterval(timer); }

  dots.forEach(function (d, i) {
    d.addEventListener('click', function () { stop(); goTo(i); start(); });
  });
  wrap.addEventListener('mouseenter', stop);
  wrap.addEventListener('mouseleave', start);
  start();
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Hero split",
  "tag": "div",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Occhiello",
      "default": "Milano · via Merano 18 · dal 2016"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Citazione / Headline",
      "default": "«I vostri figli e i vostri nipoti vi ricorderanno e vi giudicheranno anche dai mobili ereditati.»"
    },
    {
      "type": "text",
      "id": "author",
      "label": "Autore citazione",
      "default": "— Dino Gavina"
    },
    { "type": "header", "content": "CTA principale" },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "Testo pulsante 1",
      "default": "Scopri i prodotti"
    },
    {
      "type": "url",
      "id": "cta1_link",
      "label": "Link pulsante 1"
    },
    { "type": "header", "content": "CTA secondaria" },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Testo pulsante 2",
      "default": "Richiedi noleggio"
    },
    {
      "type": "url",
      "id": "cta2_link",
      "label": "Link pulsante 2"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Didascalia"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero split M76",
      "blocks": [
        { "type": "slide", "settings": { "caption": "Showroom Milano · via Merano 18" } },
        { "type": "slide", "settings": { "caption": "Design italiano e internazionale" } },
        { "type": "slide", "settings": { "caption": "Modernariato · Pezzi unici" } }
      ]
    }
  ]
}
{% endschema %}
