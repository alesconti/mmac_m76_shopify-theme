<style>
.m76-services { background: #1d2440; padding: 80px 52px; }
.m76-services__title {
  font-family: 'Playfair Display', serif;
  font-size: 42px;
  font-weight: 400;
  color: #fff;
  margin: 0 0 52px;
}
.m76-services__grid {
  display: grid;
  grid-template-columns: repeat({{ section.blocks.size | at_most: 3 }}, 1fr);
  gap: 1px;
  background: rgba(255,255,255,.07);
}
.m76-srv-card { background: #1d2440; padding: 40px 36px 52px; }
.m76-srv-card__icon {
  width: 40px;
  height: 40px;
  margin-bottom: 28px;
  display: flex;
  align-items: center;
}
.m76-srv-card__icon svg { width: 32px; height: 32px; stroke: rgba(255,255,255,.4); fill: none; stroke-width: 1.5; }
.m76-srv-card__title {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  color: #fff;
  margin: 0 0 16px;
}
.m76-srv-card__desc {
  font-family: 'Poppins', sans-serif;
  font-size: 16px;
  font-weight: 300;
  color: rgba(255,255,255,.45);
  line-height: 1.85;
  margin: 0 0 28px;
}
.m76-srv-card__link {
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #f4f4d0;
  text-decoration: none;
  border-bottom: 1px solid rgba(244,244,208,.3);
  padding-bottom: 2px;
  transition: border-color .2s;
}
.m76-srv-card__link:hover { border-color: #f4f4d0; }
@media (max-width: 989px) {
  .m76-services { padding: 48px 20px; }
  .m76-services__grid { grid-template-columns: 1fr; gap: 0; }
  .m76-srv-card { border-bottom: 1px solid rgba(255,255,255,.07); }
  .m76-services__title { font-size: 28px; }
}
</style>

<section class="m76-services">
  {%- if section.settings.heading != blank -%}
    <h2 class="m76-services__title">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="m76-services__grid">
    {%- for block in section.blocks -%}
      <div class="m76-srv-card" {{ block.shopify_attributes }}>
        {%- case block.settings.icon -%}
          {%- when 'bag' -%}
            <div class="m76-srv-card__icon">
              <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            </div>
          {%- when 'camera' -%}
            <div class="m76-srv-card__icon">
              <svg viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </div>
          {%- when 'tool' -%}
            <div class="m76-srv-card__icon">
              <svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
          {%- when 'calendar' -%}
            <div class="m76-srv-card__icon">
              <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
          {%- else -%}
            <div class="m76-srv-card__icon">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            </div>
        {%- endcase -%}

        <h3 class="m76-srv-card__title">{{ block.settings.title }}</h3>
        {%- if block.settings.desc != blank -%}
          <p class="m76-srv-card__desc">{{ block.settings.desc }}</p>
        {%- endif -%}
        {%- if block.settings.link_label != blank and block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="m76-srv-card__link">{{ block.settings.link_label }}</a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Servizi",
  "tag": "div",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo sezione",
      "default": "I nostri servizi"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Servizio",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icona",
          "options": [
            { "value": "bag",    "label": "Borsa / Vendita" },
            { "value": "camera", "label": "Fotocamera / Noleggio" },
            { "value": "tool",     "label": "Utensile / Restauro" },
            { "value": "calendar", "label": "Calendario / Noleggio" },
            { "value": "plus",     "label": "Plus generico" }
          ],
          "default": "bag"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titolo servizio",
          "default": "Vendita"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "Descrizione",
          "default": "Antiquariato, modernariato e design d'autore. Ogni pezzo è selezionato, restaurato e certificato prima di entrare in catalogo."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Testo link",
          "default": "Sfoglia il catalogo"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Servizi M76",
      "blocks": [
        { "type": "service", "settings": { "icon": "bag",    "title": "Vendita",            "link_label": "Sfoglia il catalogo" } },
        { "type": "service", "settings": { "icon": "camera", "title": "Noleggio & Set",      "link_label": "Richiedi un preventivo" } },
        { "type": "service", "settings": { "icon": "tool",   "title": "Restauro Artigianale","link_label": "Scopri il servizio" } }
      ]
    }
  ]
}
{% endschema %}
