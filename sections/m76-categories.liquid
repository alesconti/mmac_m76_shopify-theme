<style>
.m76-cats { padding: 72px 52px 0; }
.m76-cats__header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 32px; }
.m76-cats__title { font-family: 'Playfair Display', serif; font-size: 42px; font-weight: 400; color: #1d2440; margin: 0; }
.m76-cats__more { font-family: 'Poppins', sans-serif; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: #8a8c96; text-decoration: none; transition: color .2s; }
.m76-cats__more:hover { color: #1d2440; }
.m76-cats__grid { display: grid; grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr); gap: 1px; background: #e4e4dc; }
.m76-cat-card { aspect-ratio: 3/4; position: relative; overflow: hidden; background: #f8f8f4; display: block; text-decoration: none; }
.m76-cat-card img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; display: block; }
.m76-cat-card:hover img { transform: scale(1.04); }
.m76-cat-card__overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(29,36,64,.85) 0%, transparent 55%); }
.m76-cat-card__info { position: absolute; bottom: 0; left: 0; right: 0; padding: 28px; }
.m76-cat-card__name { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 400; color: #fff; margin: 0 0 8px; }
.m76-cat-card__sub { font-family: 'Poppins', sans-serif; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,.55); }
@media (max-width: 989px) {
  .m76-cats { padding: 48px 20px 0; }
  .m76-cats__grid { grid-template-columns: repeat(2, 1fr); }
  .m76-cats__title { font-size: 28px; }
}
@media (max-width: 599px) {
  .m76-cats__grid { grid-template-columns: 1fr 1fr; }
  .m76-cat-card__name { font-size: 20px; }
}
</style>

<section class="m76-cats">
  {%- if section.settings.heading != blank or section.settings.link_label != blank -%}
    <div class="m76-cats__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="m76-cats__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.link_label != blank and section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="m76-cats__more">{{ section.settings.link_label }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="m76-cats__grid">
    {%- for block in section.blocks -%}
      <a
        class="m76-cat-card"
        href="{{ block.settings.link | default: '#' }}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          {{
            block.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              sizes: '(max-width: 989px) 50vw, 25vw',
              widths: '400, 600, 800'
          }}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        <div class="m76-cat-card__overlay"></div>
        <div class="m76-cat-card__info">
          <p class="m76-cat-card__name">{{ block.settings.name }}</p>
          {%- if block.settings.sub != blank -%}
            <p class="m76-cat-card__sub">{{ block.settings.sub }}</p>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Categorie",
  "tag": "div",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo sezione",
      "default": "Esplora per categoria"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link 'vedi tutti'",
      "default": "Tutto il catalogo →"
    },
    {
      "type": "url",
      "id": "link",
      "label": "URL 'vedi tutti'"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoria",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nome categoria",
          "default": "Sedute"
        },
        {
          "type": "text",
          "id": "sub",
          "label": "Sottotitolo",
          "default": "Poltrone, divani, sedie"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link categoria"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorie M76",
      "blocks": [
        { "type": "category", "settings": { "name": "Sedute", "sub": "Poltrone, divani, sedie" } },
        { "type": "category", "settings": { "name": "Tavoli", "sub": "Da pranzo, caffè, consolle" } },
        { "type": "category", "settings": { "name": "Lampade", "sub": "Lampadari, terra, tavolo" } },
        { "type": "category", "settings": { "name": "Mobili", "sub": "Librerie, cassettiere, credenze" } }
      ]
    }
  ]
}
{% endschema %}
