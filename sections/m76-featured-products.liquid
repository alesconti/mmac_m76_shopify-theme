<style>
.m76-featured { padding: 72px 52px; }
.m76-featured__header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 32px; }
.m76-featured__title { font-family: 'Playfair Display', serif; font-size: 42px; font-weight: 400; color: #1d2440; margin: 0; }
.m76-featured__more { font-family: 'Poppins', sans-serif; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: #8a8c96; text-decoration: none; transition: color .2s; }
.m76-featured__more:hover { color: #1d2440; }
.m76-featured__grid { display: grid; grid-template-columns: repeat({{ section.settings.columns }}, 1fr); gap: 1px; background: #e4e4dc; }
.m76-prod-card { background: #fff; cursor: pointer; text-decoration: none; display: block; }
.m76-prod-card__thumb { position: relative; aspect-ratio: 1; overflow: hidden; background: #f8f8f4; }
.m76-prod-card__thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; display: block; }
.m76-prod-card:hover .m76-prod-card__thumb img { transform: scale(1.04); }
.m76-prod-card__badge { position: absolute; top: 12px; left: 12px; background: #f4f4d0; color: #1d2440; font-family: 'Poppins', sans-serif; font-size: 12px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; padding: 6px 12px; }
.m76-prod-card__badge--new { background: #1d2440; color: #f4f4d0; }
.m76-prod-card__info { padding: 16px 18px 20px; border-bottom: 1px solid #e4e4dc; }
.m76-prod-card__name { font-family: 'Playfair Display', serif; font-size: 20px; color: #1d2440; margin: 0 0 5px; line-height: 1.35; }
.m76-prod-card__vendor { font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 300; color: #8a8c96; font-style: italic; margin: 0 0 12px; }
.m76-prod-card__foot { display: flex; justify-content: space-between; align-items: center; }
.m76-prod-card__type { font-family: 'Poppins', sans-serif; font-size: 13px; letter-spacing: 1px; text-transform: uppercase; color: #8a8c96; }
.m76-prod-card__price { font-family: 'Playfair Display', serif; font-size: 20px; color: #1d2440; }

@media (max-width: 989px) {
  .m76-featured { padding: 48px 20px; }
  .m76-featured__grid { grid-template-columns: repeat(2, 1fr); }
  .m76-featured__title { font-size: 28px; }
}
@media (max-width: 599px) {
  .m76-featured__grid { grid-template-columns: 1fr 1fr; }
}
</style>

{%- assign feat_collection = collections[section.settings.collection] -%}

<section class="m76-featured">
  <div class="m76-featured__header">
    <h2 class="m76-featured__title">{{ section.settings.heading }}</h2>
    {%- if feat_collection != blank -%}
      <a href="{{ feat_collection.url }}" class="m76-featured__more">
        {{ section.settings.link_label | default: 'Vedi tutti' }} →
      </a>
    {%- endif -%}
  </div>

  <div class="m76-featured__grid">
    {%- if feat_collection != blank -%}
      {%- for product in feat_collection.products limit: section.settings.products_count -%}
        <a class="m76-prod-card" href="{{ product.url }}">
          <div class="m76-prod-card__thumb">
            {%- if product.featured_media -%}
              {{
                product.featured_media
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  alt: product.featured_media.alt | default: product.title,
                  sizes: '(max-width: 989px) 50vw, 25vw',
                  widths: '400, 600, 800'
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            {%- if product.metafields.custom.badge != blank -%}
              <span class="m76-prod-card__badge">{{ product.metafields.custom.badge }}</span>
            {%- elsif product.tags contains 'nuovo-arrivo' -%}
              <span class="m76-prod-card__badge m76-prod-card__badge--new">Appena arrivato</span>
            {%- endif -%}
          </div>
          <div class="m76-prod-card__info">
            <p class="m76-prod-card__name">{{ product.title }}</p>
            <p class="m76-prod-card__vendor">{{ product.vendor }}</p>
            <div class="m76-prod-card__foot">
              <span class="m76-prod-card__type">{{ product.type }}</span>
              <span class="m76-prod-card__price">
                {%- if product.price == 0 -%}
                  Su richiesta
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..section.settings.products_count) -%}
        <div class="m76-prod-card">
          <div class="m76-prod-card__thumb">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}</div>
          <div class="m76-prod-card__info">
            <p class="m76-prod-card__name">Esempio prodotto {{ i }}</p>
            <p class="m76-prod-card__vendor">Designer / Produttore</p>
            <div class="m76-prod-card__foot">
              <span class="m76-prod-card__type">1960 ca.</span>
              <span class="m76-prod-card__price">Su richiesta</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Prodotti in evidenza",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo sezione",
      "default": "Pezzi in evidenza"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Testo link 'vedi tutti'",
      "default": "Vedi tutti i prodotti"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collezione da mostrare"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Numero prodotti",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Colonne (desktop)",
      "options": [
        { "value": "3", "label": "3 colonne" },
        { "value": "4", "label": "4 colonne" }
      ],
      "default": "4"
    }
  ],
  "presets": [{ "name": "Prodotti in evidenza M76" }]
}
{% endschema %}
