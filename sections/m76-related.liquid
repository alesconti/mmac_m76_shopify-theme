<style>
.m76-rel { padding: 48px 52px 72px; border-top: 1px solid #e4e4dc; }
.m76-rel__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(24px, 2.2vw, 32px);
  font-weight: 400;
  color: #1d2440;
  margin: 0 0 28px;
}
.m76-rel__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: #e4e4dc;
}
.m76-rel__card { background: #fff; text-decoration: none; display: block; }
.m76-rel__thumb { aspect-ratio: 1; overflow: hidden; background: #f8f8f4; }
.m76-rel__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .6s ease; }
.m76-rel__card:hover .m76-rel__thumb img { transform: scale(1.04); }
.m76-rel__info { padding: 14px 16px 18px; }
.m76-rel__name {
  font-family: 'Playfair Display', serif;
  font-size: 17px;
  color: #1d2440;
  margin: 0 0 4px;
  line-height: 1.3;
}
.m76-rel__vendor {
  font-family: 'Poppins', sans-serif;
  font-size: 13px;
  font-weight: 300;
  font-style: italic;
  color: #8a8c96;
  margin: 0 0 12px;
}
.m76-rel__foot { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
.m76-rel__type {
  font-family: 'Poppins', sans-serif;
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #8a8c96;
}
.m76-rel__price {
  font-family: 'Playfair Display', serif;
  font-size: 17px;
  color: #1d2440;
}
@media (max-width: 989px) {
  .m76-rel { padding: 40px 20px; }
  .m76-rel__grid { grid-template-columns: repeat(2, 1fr); }
}
</style>

{%- liquid
  assign source = product.collections.first
  for c in product.collections
    if c.title == product.type
      assign source = c
    endif
  endfor

  assign max_related = 4
  assign pool_limit = 50

  assign my_creators = product.metafields.m76.creator.value
  assign my_designer = blank
  assign my_producer = blank
  if my_creators.size > 0
    assign my_designer = my_creators[0]
  endif
  if my_creators.size > 1
    assign my_producer = my_creators[1]
  endif
  assign my_color = product.metafields.m76.color.value
-%}

{%- if source != blank -%}
  {%- liquid
    assign shown = 0
    assign shown_ids = ','
  -%}
  <section class="m76-rel">
    <h2 class="m76-rel__title">{{ section.settings.heading }}</h2>
    <div class="m76-rel__grid">
      {%- comment -%}
        Priorità di abbinamento: prodotti che condividono più attributi con
        quello corrente (designer, produttore, colore) vengono mostrati per primi.
        Tier 3 = tutti e 3 gli attributi in comune, poi 2, poi 1.
      {%- endcomment -%}
      {%- for target_score in (1..3) reversed -%}
        {%- if shown >= max_related -%}{%- break -%}{%- endif -%}
        {%- for related in source.products limit: pool_limit -%}
          {%- if shown >= max_related -%}{%- break -%}{%- endif -%}
          {%- assign rel_key = related.id | prepend: ',' | append: ',' -%}
          {%- if related.id == product.id or shown_ids contains rel_key -%}{%- continue -%}{%- endif -%}

          {%- assign rel_creators = related.metafields.m76.creator.value -%}
          {%- assign rel_designer = blank -%}
          {%- assign rel_producer = blank -%}
          {%- if rel_creators.size > 0 -%}{%- assign rel_designer = rel_creators[0] -%}{%- endif -%}
          {%- if rel_creators.size > 1 -%}{%- assign rel_producer = rel_creators[1] -%}{%- endif -%}
          {%- assign rel_color = related.metafields.m76.color.value -%}

          {%- assign match_score = 0 -%}
          {%- if my_designer != blank and rel_designer == my_designer -%}{%- assign match_score = match_score | plus: 1 -%}{%- endif -%}
          {%- if my_producer != blank and rel_producer == my_producer -%}{%- assign match_score = match_score | plus: 1 -%}{%- endif -%}
          {%- if my_color != blank and rel_color == my_color -%}{%- assign match_score = match_score | plus: 1 -%}{%- endif -%}

          {%- if match_score == target_score -%}
            {%- assign shown_ids = shown_ids | append: related.id | append: ',' -%}
            {%- assign shown = shown | plus: 1 -%}
            {%- render 'm76-related-card', related: related -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}

      {%- comment -%} Riempi eventuali slot rimasti con prodotti della stessa categoria (nessun attributo in comune) {%- endcomment -%}
      {%- if shown < max_related -%}
        {%- for related in source.products limit: pool_limit -%}
          {%- if shown >= max_related -%}{%- break -%}{%- endif -%}
          {%- assign rel_key = related.id | prepend: ',' | append: ',' -%}
          {%- if related.id == product.id or shown_ids contains rel_key -%}{%- continue -%}{%- endif -%}
          {%- assign shown_ids = shown_ids | append: related.id | append: ',' -%}
          {%- assign shown = shown | plus: 1 -%}
          {%- render 'm76-related-card', related: related -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "M76 Prodotti correlati",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "Potrebbe interessarti anche"
    }
  ],
  "presets": [{ "name": "M76 Prodotti correlati" }]
}
{% endschema %}
