{{ 'magazzino76.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_social = false
  if settings.social_instagram_link != blank or settings.social_facebook_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_twitter_link != blank
    assign has_social = true
  endif
-%}

<footer class="m76-footer">

  <!-- Top grid: logo col + up to 3 menu/text blocks -->
  <div class="m76-footer__top">

    <!-- Col 1: Logo + tagline -->
    <div>
      {%- if settings.logo != blank -%}
        <div class="m76-footer__logo">
          {{
            settings.logo
            | image_url: width: 400
            | image_tag:
              alt: shop.name,
              loading: 'lazy',
              width: settings.logo_width
          }}
        </div>
      {%- else -%}
        <p style="font-family:var(--m76-serif);font-size:20px;color:#fff;margin:0 0 16px;">{{ shop.name }}</p>
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}
        <p class="m76-footer__tagline">{{ section.settings.tagline | newline_to_br }}</p>
      {%- endif -%}
    </div>

    <!-- Cols 2–4: link_list blocks -->
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'link_list' -%}
          <div {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <p class="m76-footer__col-title">{{ block.settings.heading | escape }}</p>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="m76-footer__links" role="list">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

        {%- when 'text' -%}
          <div {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <p class="m76-footer__col-title">{{ block.settings.heading | escape }}</p>
            {%- endif -%}
            {%- if block.settings.subtext != blank -%}
              <ul class="m76-footer__links" role="list">
                {%- assign lines = block.settings.subtext | strip_html | newline_to_br | split: '<br />' -%}
                {%- for line in lines -%}
                  {%- assign l = line | strip -%}
                  {%- if l != blank -%}
                    <li><span>{{ l }}</span></li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

      {%- endcase -%}
    {%- endfor -%}

  </div><!-- /.m76-footer__top -->

  <!-- Bottom bar -->
  <div class="m76-footer__bottom">
    <p class="m76-footer__copy">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
      {%- if section.settings.vat != blank %} &middot; {{ section.settings.vat }}{%- endif -%}
    </p>

    {%- if has_social -%}
      <div class="m76-footer__social">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline sotto il logo",
      "default": "ANTIQUARIATO\nMODERNARIATO\nDESIGN STORICIZZATO"
    },
    {
      "type": "text",
      "id": "vat",
      "label": "P.IVA / Info legale",
      "default": "P.IVA 11137560964"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu di link",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titolo colonna",
          "default": "Navigazione"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Testo libero",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titolo colonna",
          "default": "Contatti"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Testo (una riga = un elemento)",
          "default": "via Merano 18, Milano\n+39 02 39525097\ninfo@magazzino76.it\nLun–Sab · 10:00–19:30"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list" },
      { "type": "link_list" },
      { "type": "text" }
    ]
  }
}
{% endschema %}
