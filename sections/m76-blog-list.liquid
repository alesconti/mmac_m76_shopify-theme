<style>
.m76-blog {
  padding: 72px 52px;
  max-width: 1100px;
}
.m76-blog__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 3.2vw, 48px);
  font-weight: 400;
  color: #1d2440;
  line-height: 1.2;
  margin: 0 0 24px;
  max-width: 640px;
}
.m76-blog__body {
  font-family: 'Poppins', sans-serif;
  font-size: 15px;
  font-weight: 300;
  color: #1d2440;
  opacity: .8;
  line-height: 1.75;
  margin: 0 0 12px;
  max-width: 760px;
}
.m76-blog__body a { color: #1d2440; }
.m76-blog__list {
  list-style: none;
  margin: 48px 0 0;
  padding: 0;
}
.m76-blog__row a {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 32px;
  padding: 22px 0;
  border-bottom: 1px solid #e4e4dc;
  text-decoration: none;
  transition: opacity .2s;
}
.m76-blog__row:first-child a { border-top: 1px solid #e4e4dc; }
.m76-blog__row a:hover { opacity: .55; }
.m76-blog__row-title {
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #1d2440;
  margin: 0;
}
.m76-blog__row-date {
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  font-weight: 300;
  color: #8a8c96;
  white-space: nowrap;
}
.m76-blog__pagination {
  margin-top: 40px;
  display: flex;
  gap: 18px;
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
}
.m76-blog__pagination a, .m76-blog__pagination span { color: #1d2440; text-decoration: none; }
.m76-blog__pagination span.current { border-bottom: 1.5px solid #1d2440; }
@media (max-width: 749px) {
  .m76-blog { padding: 48px 20px; }
  .m76-blog__row a { flex-direction: column; gap: 6px; }
}
</style>

<section class="m76-blog">
  {%- if section.settings.heading != blank -%}
    <h1 class="m76-blog__title">{{ section.settings.heading }}</h1>
  {%- endif -%}
  {%- if section.settings.body != blank -%}
    <div class="m76-blog__body">{{ section.settings.body }}</div>
  {%- endif -%}

  {%- paginate blog.articles by 20 -%}
    <ul class="m76-blog__list" role="list">
      {%- for article in blog.articles -%}
        <li class="m76-blog__row">
          <a href="{{ article.url }}">
            <h2 class="m76-blog__row-title">{{ article.title }}</h2>
            <span class="m76-blog__row-date">{{ article.published_at | date: format: 'date' }}</span>
          </a>
        </li>
      {%- else -%}
        <li class="m76-blog__row" style="padding: 22px 0; font-family: 'Poppins', sans-serif; font-size: 14px; color: #8a8c96;">{{ 'm76.blog.empty' | t }}</li>
      {%- endfor -%}
    </ul>
    {%- if paginate.pages > 1 -%}
      <nav class="m76-blog__pagination" aria-label="{{ 'm76.general.pagination' | t }}">
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}
            <span class="{% if part.title == paginate.current_page %}current{% endif %}">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "M76 Elenco eventi",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo (vuoto = nome blog)"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Testo introduttivo"
    }
  ]
}
{% endschema %}
