<style>
.m76-steps {
  background: #1d2440;
  padding: 72px 52px;
}
.m76-steps__title {
  font-family: 'Playfair Display', serif;
  font-size: 42px;
  font-weight: 400;
  color: #fff;
  margin: 0 0 40px;
}
.m76-steps__grid {
  display: grid;
  grid-template-columns: repeat({{ section.blocks.size | at_least: 1 }}, 1fr);
}
.m76-steps__step {
  padding: 8px 40px 24px 0;
}
.m76-steps__step + .m76-steps__step {
  border-left: 1px solid rgba(255, 255, 255, .12);
  padding-left: 40px;
}
.m76-steps__num {
  font-family: 'Playfair Display', serif;
  font-size: 54px;
  color: rgba(255, 255, 255, .25);
  margin: 0 0 14px;
  line-height: 1;
}
.m76-steps__step-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  font-weight: 400;
  color: #fff;
  margin: 0 0 10px;
}
.m76-steps__step-text {
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: rgba(255, 255, 255, .55);
  line-height: 1.7;
  margin: 0;
}
@media (max-width: 989px) {
  .m76-steps { padding: 48px 20px; }
  .m76-steps__title { font-size: 28px; }
  .m76-steps__grid { grid-template-columns: 1fr; gap: 28px; }
  .m76-steps__step + .m76-steps__step { border-left: none; padding-left: 0; border-top: 1px solid rgba(255,255,255,.12); padding-top: 28px; }
}
</style>

<section class="m76-steps">
  {%- if section.settings.heading != blank -%}
    <h2 class="m76-steps__title">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="m76-steps__grid">
    {%- for block in section.blocks -%}
      <div class="m76-steps__step" {{ block.shopify_attributes }}>
        <p class="m76-steps__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</p>
        <h3 class="m76-steps__step-title">{{ block.settings.title }}</h3>
        <p class="m76-steps__step-text">{{ block.settings.text }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "M76 Passaggi",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "Come funziona"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Passaggio",
      "settings": [
        { "type": "text", "id": "title", "label": "Titolo" },
        { "type": "textarea", "id": "text", "label": "Testo" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "M76 Passaggi" }]
}
{% endschema %}
