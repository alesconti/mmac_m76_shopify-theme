<style>
.m76-intro-stats {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
}
.m76-intro-stats--no-panel { grid-template-columns: 1fr; }
.m76-intro-stats--no-panel .m76-intro-stats__main { max-width: 880px; }
.m76-intro-stats__main {
  padding: 72px 60px 72px 52px;
}
.m76-intro-stats__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 2.6vw, 40px);
  font-weight: 400;
  color: #1d2440;
  margin: 0 0 22px;
  line-height: 1.25;
}
.m76-intro-stats__body {
  font-family: 'Poppins', sans-serif;
  font-size: 15px;
  font-weight: 300;
  color: #1d2440;
  opacity: .8;
  line-height: 1.75;
  margin: 0 0 32px;
}
.m76-intro-stats__cta {
  display: inline-block;
  font-family: 'Poppins', sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #fff;
  background: #1d2440;
  padding: 13px 26px;
  text-decoration: none;
  transition: opacity .2s;
}
.m76-intro-stats__cta:hover { opacity: .85; }

.m76-intro-stats__panel {
  background: #f8f8f4;
  padding: 72px 52px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-content: center;
  gap: 1px;
}
.m76-intro-stats__stat {
  padding: 28px 24px;
  position: relative;
}
.m76-intro-stats__stat:nth-child(odd) { border-right: 1px solid #e4e4dc; }
.m76-intro-stats__stat:nth-child(n+3) { border-top: 1px solid #e4e4dc; }
.m76-intro-stats__stat-n {
  font-family: 'Playfair Display', serif;
  font-size: 42px;
  color: #1d2440;
  margin: 0 0 6px;
  line-height: 1.1;
}
.m76-intro-stats__stat-l {
  font-family: 'Poppins', sans-serif;
  font-size: 11px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #8a8c96;
  margin: 0;
}
@media (max-width: 989px) {
  .m76-intro-stats { grid-template-columns: 1fr; }
  .m76-intro-stats__main { padding: 48px 20px; }
  .m76-intro-stats__panel { padding: 40px 20px; }
}
</style>

<section class="m76-intro-stats{% if section.blocks.size == 0 %} m76-intro-stats--no-panel{% endif %}">
  <div class="m76-intro-stats__main">
    {%- if section.settings.heading != blank -%}
      <h2 class="m76-intro-stats__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="m76-intro-stats__body">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="m76-intro-stats__cta">{{ section.settings.cta_label }}</a>
    {%- endif -%}
  </div>
  {%- if section.blocks.size > 0 -%}
    <div class="m76-intro-stats__panel">
      {%- for block in section.blocks -%}
        <div class="m76-intro-stats__stat" {{ block.shopify_attributes }}>
          <p class="m76-intro-stats__stat-n">{{ block.settings.value }}</p>
          {%- if block.settings.label != blank -%}
            <p class="m76-intro-stats__stat-l">{{ block.settings.label }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "M76 Intro + statistiche",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Testo"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Etichetta bottone"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link bottone"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistica",
      "settings": [
        { "type": "text", "id": "value", "label": "Valore", "default": "2.400+" },
        { "type": "text", "id": "label", "label": "Etichetta (opzionale)" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "M76 Intro + statistiche" }]
}
{% endschema %}
