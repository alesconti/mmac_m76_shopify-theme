{{ 'magazzino76.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .m76-header-outer {
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign header_tag = 'div'
  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif
-%}

<!-- Overlay -->
<div class="m76-overlay" id="m76Overlay" onclick="m76CloseAll()"></div>

<!-- Mobile Drawer -->
<div class="m76-drawer" id="m76Drawer">
  <div class="m76-drawer__head">
    <button class="m76-drawer__close" onclick="m76CloseAll()" aria-label="Chiudi menu">
      <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <ul class="m76-drawer__nav">
    {%- if section.settings.menu != blank -%}
      {%- for link in section.settings.menu.links -%}
        {%- assign is_products_link = false -%}
        {%- if link.title == 'Prodotti' or link.url == routes.all_products_collection_url -%}
          {%- assign is_products_link = true -%}
        {%- endif -%}
        {%- if is_products_link -%}
          <li class="m76-drawer__item--dropdown">
            <details class="m76-drawer__details">
              <summary>
                <span>{{ link.title | escape }}</span>
                <svg class="m76-drawer__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <ul class="m76-drawer__submenu" role="list">
                <li>
                  <a href="{{ routes.root_url }}collections/sedute">
                    {{ 'icon-m76-sedute.svg' | inline_asset_content }}
                    <span>{{ collections['sedute'].title | default: 'Sedute' }}</span>
                  </a>
                </li>
                <li>
                  <a href="{{ routes.root_url }}collections/tavoli">
                    {{ 'icon-m76-tavoli.svg' | inline_asset_content }}
                    <span>{{ collections['tavoli'].title | default: 'Tavoli' }}</span>
                  </a>
                </li>
                <li>
                  <a href="{{ routes.root_url }}collections/lampade">
                    {{ 'icon-m76-lampade.svg' | inline_asset_content }}
                    <span>{{ collections['lampade'].title | default: 'Lampade' }}</span>
                  </a>
                </li>
                <li>
                  <a href="{{ routes.root_url }}collections/mobili">
                    {{ 'icon-m76-mobili.svg' | inline_asset_content }}
                    <span>{{ collections['mobili'].title | default: 'Mobili' }}</span>
                  </a>
                </li>
                <li>
                  <a href="{{ routes.root_url }}collections/specchi">
                    {{ 'icon-m76-specchi.svg' | inline_asset_content }}
                    <span>{{ collections['specchi'].title | default: 'Specchi' }}</span>
                  </a>
                </li>
                <li>
                  <a href="{{ routes.root_url }}collections/decorativi">
                    {{ 'icon-m76-decorativi.svg' | inline_asset_content }}
                    <span>{{ collections['decorativi'].title | default: 'Decorativi' }}</span>
                  </a>
                </li>
                <li>
                  <a href="{{ link.url }}" class="m76-drawer__submenu-all">{{ 'm76.general.all_products' | t }} →</a>
                </li>
              </ul>
            </details>
          </li>
        {%- else -%}
          <li>
            <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>
              {{ link.title | escape }}
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </ul>
  {%- if localization.available_languages.size > 1 -%}
    {%- form 'localization', class: 'm76-lang m76-lang--drawer' -%}
      {%- for language in localization.available_languages -%}
        {%- if language.iso_code == localization.language.iso_code -%}
          <span class="m76-lang__item m76-lang__item--active">{{ language.iso_code | upcase }}</span>
        {%- else -%}
          <button type="submit" class="m76-lang__item" name="locale_code" value="{{ language.iso_code }}" lang="{{ language.iso_code }}" aria-label="{{ language.endonym_name | capitalize }}">
            {{ language.iso_code | upcase }}
          </button>
        {%- endif -%}
        {%- unless forloop.last -%}<span class="m76-lang__sep">/</span>{%- endunless -%}
      {%- endfor -%}
    {%- endform -%}
  {%- endif -%}
</div>

<!-- Main Header -->
<{{ header_tag }}
  {% if header_tag == 'sticky-header' %}data-sticky-type="{{ section.settings.sticky_header_type }}"{% endif %}
  class="m76-header-outer"
>
  <nav class="m76-nav" role="navigation" aria-label="Navigazione principale">

    <!-- Logo -->
    {%- if request.page_type == 'index' -%}<h1 class="m76-nav__logo-heading" style="margin:0;">{%- endif -%}
    <a href="{{ routes.root_url }}" class="m76-nav__logo">
      {%- if settings.logo != blank -%}
        {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
        {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
        {{
          settings.logo
          | image_url: width: 400
          | image_tag:
            height: logo_height,
            width: settings.logo_width,
            alt: logo_alt,
            loading: 'eager'
        }}
      {%- else -%}
        <span class="m76-nav__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    {%- if request.page_type == 'index' -%}</h1>{%- endif -%}

    <!-- Desktop Nav Links -->
    {%- if section.settings.menu != blank -%}
      <ul class="m76-nav__links" role="list">
        {%- for link in section.settings.menu.links -%}
          {%- assign is_products_link = false -%}
          {%- if link.title == 'Prodotti' or link.url == routes.all_products_collection_url -%}
            {%- assign is_products_link = true -%}
          {%- endif -%}
          <li class="{% if is_products_link %}m76-nav__item--dropdown{% endif %}">
            <a
              href="{{ link.url }}"
              class="m76-nav__link{% if link.active %} m76-nav__link--active{% endif %}"
              {% if link.active %}aria-current="page"{% endif %}
            >
              {{ link.title | escape }}
            </a>
            {%- if is_products_link -%}
              <div class="m76-products-dropdown">
                <div class="m76-products-dropdown__inner">
                <div class="m76-products-dropdown__head">
                  <span class="m76-products-dropdown__title">{{ link.title }}</span>
                  <a href="{{ routes.all_products_collection_url }}" class="m76-products-dropdown__all">{{ 'm76.general.all_products' | t }} →</a>
                </div>
                <ul class="m76-products-dropdown__grid" role="list">
                  <li>
                    <a href="{{ routes.root_url }}collections/sedute">
                      {{ 'icon-m76-sedute.svg' | inline_asset_content }}
                      <span>{{ collections['sedute'].title | default: 'Sedute' }}</span>
                    </a>
                  </li>
                  <li>
                    <a href="{{ routes.root_url }}collections/tavoli">
                      {{ 'icon-m76-tavoli.svg' | inline_asset_content }}
                      <span>{{ collections['tavoli'].title | default: 'Tavoli' }}</span>
                    </a>
                  </li>
                  <li>
                    <a href="{{ routes.root_url }}collections/lampade">
                      {{ 'icon-m76-lampade.svg' | inline_asset_content }}
                      <span>{{ collections['lampade'].title | default: 'Lampade' }}</span>
                    </a>
                  </li>
                  <li>
                    <a href="{{ routes.root_url }}collections/mobili">
                      {{ 'icon-m76-mobili.svg' | inline_asset_content }}
                      <span>{{ collections['mobili'].title | default: 'Mobili' }}</span>
                    </a>
                  </li>
                  <li>
                    <a href="{{ routes.root_url }}collections/specchi">
                      {{ 'icon-m76-specchi.svg' | inline_asset_content }}
                      <span>{{ collections['specchi'].title | default: 'Specchi' }}</span>
                    </a>
                  </li>
                  <li>
                    <a href="{{ routes.root_url }}collections/decorativi">
                      {{ 'icon-m76-decorativi.svg' | inline_asset_content }}
                      <span>{{ collections['decorativi'].title | default: 'Decorativi' }}</span>
                    </a>
                  </li>
                </ul>
                </div>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    <!-- Icons -->
    <div class="m76-nav__icons">

      <!-- Language selector -->
      {%- if localization.available_languages.size > 1 -%}
        {%- form 'localization', class: 'm76-lang' -%}
          {%- for language in localization.available_languages -%}
            {%- if language.iso_code == localization.language.iso_code -%}
              <span class="m76-lang__item m76-lang__item--active">{{ language.iso_code | upcase }}</span>
            {%- else -%}
              <button type="submit" class="m76-lang__item" name="locale_code" value="{{ language.iso_code }}" lang="{{ language.iso_code }}" aria-label="{{ language.endonym_name | capitalize }}">
                {{ language.iso_code | upcase }}
              </button>
            {%- endif -%}
            {%- unless forloop.last -%}<span class="m76-lang__sep">/</span>{%- endunless -%}
          {%- endfor -%}
        {%- endform -%}
      {%- endif -%}

      <!-- Search -->
      <a href="{{ routes.search_url }}" class="m76-nav__icon m76-nav__icon--search" aria-label="{{ 'general.search.search' | t }}">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
      </a>

      <!-- Wishlist (lista desideri) — link a pagina /pages/wishlist se esiste -->
      <a href="/pages/lista-desideri" class="m76-nav__icon" aria-label="Lista desideri">
        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </a>

      <!-- Cart -->
      <a href="{{ routes.cart_url }}" class="m76-nav__icon m76-nav__icon--cart" aria-label="{{ 'templates.cart.cart' | t }}">
        <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="m76-cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      <!-- Hamburger (mobile) -->
      <button
        class="m76-hamburger"
        onclick="m76OpenMenu()"
        aria-label="{{ 'sections.header.menu' | default: 'Menu' }}"
        aria-expanded="false"
        aria-controls="m76Drawer"
      >
        <span></span><span></span><span></span>
      </button>

    </div>
  </nav>
</{{ header_tag }}>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification',
    color_scheme: section.settings.color_scheme,
    desktop_menu_type: section.settings.menu_type_desktop
  -%}
{%- endif -%}

<script>
  function m76OpenMenu() {
    document.getElementById('m76Drawer').classList.add('is-open');
    document.getElementById('m76Overlay').classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function m76CloseAll() {
    document.getElementById('m76Drawer').classList.remove('is-open');
    document.getElementById('m76Overlay').classList.remove('is-open');
    document.body.style.overflow = '';
  }
</script>

{% javascript %}
  class StickyHeader extends HTMLElement {
    constructor() { super(); }

    connectedCallback() {
      this.header = document.querySelector('.section-header') || this;
      this.headerIsAlwaysSticky =
        this.getAttribute('data-sticky-type') === 'always' ||
        this.getAttribute('data-sticky-type') === 'reduce-logo-size';
      this.headerBounds = {};
      this.setHeaderHeight();
      window.matchMedia('(max-width: 990px)').addEventListener('change', this.setHeaderHeight.bind(this));
      if (this.headerIsAlwaysSticky) this.header.classList.add('shopify-section-header-sticky');
      this.currentScrollTop = 0;
      this.preventReveal = false;
      this.onScrollHandler = this.onScroll.bind(this);
      this.hideHeaderOnScrollUp = () => (this.preventReveal = true);
      this.addEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.addEventListener('scroll', this.onScrollHandler, false);
      this.createObserver();
    }

    setHeaderHeight() {
      document.documentElement.style.setProperty('--header-height', `${this.offsetHeight}px`);
    }

    disconnectedCallback() {
      this.removeEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.removeEventListener('scroll', this.onScrollHandler);
    }

    createObserver() {
      let observer = new IntersectionObserver((entries, observer) => {
        this.headerBounds = entries[0].intersectionRect;
        observer.disconnect();
      });
      observer.observe(this);
    }

    onScroll() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      if (scrollTop > this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        if (this.preventHide) return;
        requestAnimationFrame(this.hide.bind(this));
      } else if (scrollTop < this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        if (!this.preventReveal) {
          requestAnimationFrame(this.reveal.bind(this));
        } else {
          window.clearTimeout(this.isScrolling);
          this.isScrolling = setTimeout(() => { this.preventReveal = false; }, 66);
          requestAnimationFrame(this.hide.bind(this));
        }
      }
      this.currentScrollTop = scrollTop;
    }

    hide() {
      if (this.headerIsAlwaysSticky) return;
      this.classList.add('shopify-section-header-hidden', 'shopify-section-header-sticky');
    }

    reveal() {
      if (this.headerIsAlwaysSticky) return;
      this.classList.add('shopify-section-header-sticky', 'animate');
      this.classList.remove('shopify-section-header-hidden');
    }

    reset() {
      if (this.headerIsAlwaysSticky) return;
      this.classList.remove('shopify-section-header-hidden', 'shopify-section-header-sticky', 'animate');
    }
  }
  customElements.define('sticky-header', StickyHeader);
{% endjavascript %}

<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  {% if settings.logo %}"logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},{% endif %}
  "url": {{ request.origin | json }}
}
</script>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu di navigazione"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        { "value": "none",          "label": "Nessuno" },
        { "value": "on-scroll-up",  "label": "Visibile allo scroll verso l'alto" },
        { "value": "always",        "label": "Sempre visibile" }
      ],
      "default": "always",
      "label": "Comportamento header"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margine inferiore",
      "default": 0
    }
  ]
}
{% endschema %}
