<style>
.m76-newsletter { background: #f8f8f4; padding: 80px 52px; }
.m76-newsletter__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 64px;
}
.m76-newsletter__title {
  font-family: 'Playfair Display', serif;
  font-size: 42px;
  font-weight: 400;
  color: #1d2440;
  line-height: 1.2;
  margin: 0 0 16px;
}
.m76-newsletter__sub {
  font-family: 'Poppins', sans-serif;
  font-size: 17px;
  font-weight: 300;
  color: #1d2440;
  opacity: .65;
  line-height: 1.75;
  margin: 0;
}
.m76-newsletter__form { display: flex; }
.m76-newsletter__input {
  flex: 1;
  border: 1px solid rgba(29,36,64,.25);
  border-right: none;
  background: rgba(255,255,255,.5);
  padding: 14px 18px;
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: #1d2440;
  outline: none;
  transition: border-color .2s, background .2s;
  -webkit-appearance: none;
  border-radius: 0;
}
.m76-newsletter__input::placeholder { color: rgba(29,36,64,.4); }
.m76-newsletter__input:focus { border-color: #1d2440; background: #fff; }
.m76-newsletter__btn {
  background: #1d2440;
  color: #fff;
  border: 1px solid #1d2440;
  padding: 14px 28px;
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity .2s;
  white-space: nowrap;
  border-radius: 0;
}
.m76-newsletter__btn:hover { opacity: .8; }
.m76-newsletter__note {
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  font-weight: 300;
  color: rgba(29,36,64,.45);
  margin: 12px 0 0;
}
.m76-newsletter__success {
  font-family: 'Poppins', sans-serif;
  font-size: 15px;
  font-weight: 300;
  color: #1d2440;
  padding: 14px 0;
}

@media (max-width: 989px) {
  .m76-newsletter { padding: 56px 20px; }
  .m76-newsletter__inner { grid-template-columns: 1fr; gap: 32px; }
  .m76-newsletter__title { font-size: 30px; }
}
@media (max-width: 599px) {
  .m76-newsletter__form { flex-direction: column; }
  .m76-newsletter__input { border-right: 1px solid rgba(29,36,64,.25); border-bottom: none; }
}
</style>

<section class="m76-newsletter">
  <div class="m76-newsletter__inner">

    <div>
      {%- if section.settings.title != blank -%}
        <h2 class="m76-newsletter__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.sub != blank -%}
        <p class="m76-newsletter__sub">{{ section.settings.sub }}</p>
      {%- endif -%}
    </div>

    <div>
      {%- form 'customer', id: 'm76-newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <p class="m76-newsletter__success">
            {{ section.settings.success_msg | default: "Grazie per l'iscrizione!" }}
          </p>
        {%- else -%}
          <div class="m76-newsletter__form">
            <input
              type="email"
              name="contact[email]"
              class="m76-newsletter__input"
              value="{{ form.email }}"
              placeholder="{{ section.settings.placeholder | default: 'La tua email' }}"
              aria-label="{{ section.settings.placeholder | default: 'La tua email' }}"
              autocomplete="email"
              required
              {% if form.errors %}aria-invalid="true"{% endif %}
            >
            <button type="submit" class="m76-newsletter__btn">
              {{ section.settings.btn_label | default: 'Iscriviti' }}
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}

      {%- if section.settings.note != blank -%}
        <p class="m76-newsletter__note">{{ section.settings.note }}</p>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titolo",
      "default": "Non perdere nessun arrivo."
    },
    {
      "type": "text",
      "id": "sub",
      "label": "Sottotitolo",
      "default": "Nuovi pezzi, eventi in store, storie dal magazzino. Nella tua inbox, senza spam."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder campo email",
      "default": "La tua email"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Testo pulsante",
      "default": "Iscriviti"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Nota sotto il form",
      "default": "Puoi disiscriverti in qualsiasi momento."
    },
    {
      "type": "text",
      "id": "success_msg",
      "label": "Messaggio di conferma",
      "default": "Grazie! Ti aggiorneremo sui nuovi arrivi."
    }
  ],
  "presets": [{ "name": "Newsletter M76" }]
}
{% endschema %}
