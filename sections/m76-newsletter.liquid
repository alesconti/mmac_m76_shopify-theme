<style>
.m76-newsletter { background: #f4f4d0; padding: 80px 52px; text-align: center; }
.m76-newsletter__inner { max-width: 560px; margin: 0 auto; }
.m76-newsletter__title {
  font-family: 'Playfair Display', serif;
  font-size: 46px;
  font-weight: 400;
  color: #1d2440;
  line-height: 1.2;
  margin: 0 0 16px;
}
.m76-newsletter__sub {
  font-family: 'Poppins', sans-serif;
  font-size: 17px;
  font-weight: 300;
  color: #1d2440;
  opacity: .65;
  line-height: 1.7;
  margin: 0 0 36px;
}
.m76-newsletter__form { display: flex; gap: 0; max-width: 460px; margin: 0 auto; }
.m76-newsletter__input {
  flex: 1;
  border: 1px solid rgba(29,36,64,.25);
  border-right: none;
  background: rgba(255,255,255,.5);
  padding: 14px 18px;
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: #1d2440;
  outline: none;
  transition: border-color .2s, background .2s;
}
.m76-newsletter__input::placeholder { color: rgba(29,36,64,.4); }
.m76-newsletter__input:focus { border-color: #1d2440; background: #fff; }
.m76-newsletter__btn {
  background: #1d2440;
  color: #fff;
  border: 1px solid #1d2440;
  padding: 14px 28px;
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity .2s;
  white-space: nowrap;
}
.m76-newsletter__btn:hover { opacity: .8; }
.m76-newsletter__success {
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: #1d2440;
  margin-top: 16px;
}
@media (max-width: 749px) {
  .m76-newsletter { padding: 48px 20px; }
  .m76-newsletter__title { font-size: 30px; }
  .m76-newsletter__form { flex-direction: column; }
  .m76-newsletter__input { border-right: 1px solid rgba(29,36,64,.25); border-bottom: none; }
}
</style>

<section class="m76-newsletter">
  <div class="m76-newsletter__inner">
    {%- if section.settings.title != blank -%}
      <h2 class="m76-newsletter__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.sub != blank -%}
      <p class="m76-newsletter__sub">{{ section.settings.sub }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'm76-newsletter-form', class: 'm76-newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <p class="m76-newsletter__success">
          {{ section.settings.success_msg | default: 'Grazie per l\'iscrizione!' }}
        </p>
      {%- else -%}
        <input
          type="email"
          name="contact[email]"
          class="m76-newsletter__input"
          value="{{ form.email }}"
          placeholder="{{ section.settings.placeholder | default: 'La tua email' }}"
          aria-label="{{ section.settings.placeholder | default: 'La tua email' }}"
          autocomplete="email"
          required
          {% if form.errors %}aria-invalid="true"{% endif %}
        >
        <button type="submit" class="m76-newsletter__btn">
          {{ section.settings.btn_label | default: 'Iscriviti' }}
        </button>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titolo",
      "default": "Rimani aggiornato"
    },
    {
      "type": "text",
      "id": "sub",
      "label": "Sottotitolo",
      "default": "Nuovi arrivi, storie di restauro e appuntamenti in showroom."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder campo email",
      "default": "La tua email"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Testo pulsante",
      "default": "Iscriviti"
    },
    {
      "type": "text",
      "id": "success_msg",
      "label": "Messaggio di conferma",
      "default": "Grazie! Ti aggiorneremo sui nuovi arrivi."
    }
  ],
  "presets": [{ "name": "Newsletter M76" }]
}
{% endschema %}
